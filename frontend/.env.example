# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# Email Configuration (Resend - works on Vercel)
# Sign up at resend.com, get API key, verify your domain
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Portfolio <noreply@yourdomain.com>
EMAIL_USER=your_email@gmail.com

# Admin Dashboard Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# GitHub API (for real heatmap and stats in portfolio)
# Create token: GitHub → Settings → Developer settings → Personal access tokens
# Required scopes: read:user, repo (for private repos; public_repo for public only)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username
